root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.{js,ts,svelte,json,yml,yaml}]
indent_style = tab
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
